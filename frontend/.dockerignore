# Docker构建忽略文件 - 防止复制不必要的文件到构建上下文

# 依赖目录
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 构建输出（必须重新构建）
dist/
dist-ssr/
*.local

# IDE和编辑器
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Git
.git/
.gitignore
.gitattributes

# Docker
Dockerfile
.dockerignore
docker-compose*.yml

# 测试和文档
coverage/
.nyc_output/
*.md
!README.md

# 其他
.env*
*.log
