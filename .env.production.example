# ========== 生产环境配置示例 ==========
# 复制此文件为 .env.production 并填写真实值

# ========== 环境标识 ==========
NODE_ENV=production

# ========== 数据库配置 ==========
DB_HOST=your-cloud-db-host
DB_PORT=5432
DB_NAME=exam_db
DB_USER=exam_user
DB_PASSWORD=<请使用强密码，建议32位随机字符>
# 生成强密码: openssl rand -base64 32

# ========== Redis配置 ==========
REDIS_HOST=your-cloud-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=<请使用强密码>

# ========== JWT配置（重要！） ==========
# 生成强密钥: openssl rand -base64 32
JWT_SECRET=<请使用32位强密钥，生产环境必须更改！>
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ========== CORS配置 ==========
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ========== SSL/HTTPS配置 ==========
SSL_CERT_PATH=/etc/letsencrypt/live/your-domain.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/your-domain.com/privkey.pem

# ========== 邮件服务配置 ==========
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=<邮件密码>
SMTP_FROM=noreply@your-domain.com
SMTP_SECURE=true
FRONTEND_URL=https://your-domain.com

# 邮件服务提供商选择：smtp, sendgrid, alicloud, mock
# mock模式：开发环境使用，邮件不发送但记录到日志

# ========== 监控和日志 ==========
LOG_LEVEL=warn
SENTRY_DSN=<your-sentry-dsn-for-error-tracking>

# ========== 速率限制配置 ==========
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_REQUESTS=10

# ========== 会话配置 ==========
SESSION_SECRET=<另一个强密钥，用于会话加密>
SESSION_MAX_AGE=1800000

# ========== 文件上传配置 ==========
MAX_FILE_SIZE=5242880
UPLOAD_WHITELIST=image/jpeg,image/png,image/gif,application/pdf

# ========== 备份配置 ==========
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# ========== 安全通知配置 ==========
SECURITY_EMAIL_ENABLED=true
SECURITY_EMAIL_FROM=security@your-domain.com
SECURITY_EMAIL_TO=admin@your-domain.com

# ========== 第三方服务（可选） ==========
# Google Analytics
GA_TRACKING_ID=

# Sentry错误追踪
SENTRY_ENVIRONMENT=production

# CDN配置
CDN_URL=

# ========== 应用配置 ==========
PORT=3000
FRONTEND_PORT=18080

# ========== 特性开关 ==========
FEATURE_REGISTRATION_ENABLED=true
FEATURE_PASSWORD_RESET_ENABLED=true
FEATURE_TWO_FACTOR_ENABLED=false
FEATURE_API_DOCUMENTATION_ENABLED=true

# ========== 高级配置 ==========
# 信任代理（Nginx反向代理）
TRUST_PROXY=true

# 请求体大小限制
BODY_LIMIT=10mb

# 并发连接数限制
CONNECTION_LIMIT=100

# ========== 告警配置 ==========
ALERT_EMAIL_ENABLED=true
ALERT_EMAIL_SMTP_HOST=smtp.your-provider.com
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_FROM=alerts@your-domain.com
ALERT_EMAIL_TO=ops@your-domain.com

# ========== 性能监控 ==========
PERFORMANCE_MONITORING_ENABLED=true
RESPONSE_TIME_THRESHOLD=1000
MEMORY_THRESHOLD=80
CPU_THRESHOLD=80

# ========== 备用配置 ==========
# 数据库连接池
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000

# Redis连接池
REDIS_POOL_MIN=2
REDIS_POOL_MAX=10

# ========== 应急配置 ==========
MAINTENANCE_MODE=false
EMERGENCY_CONTACT_EMAIL=emergency@your-domain.com
EMERGENCY_CONTACT_PHONE=+86-XXX-XXXX-XXXX