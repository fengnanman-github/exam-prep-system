{
  "permissions": {
    "allow": [
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(npm:*)",
      "Bash(node:*)",
      "Bash(psql:*)",
      "Bash(curl:*)",
      "Bash(systemctl:*)",
      "Bash(service:*)",
      "Bash(netstat:*)",
      "Bash(pkill:*)",
      "Bash(chmod:*)",
      "Bash(cat:*)",
      "Read:frontend/**",
      "Read:backend/**",
      "Edit:frontend/**",
      "Edit:backend/**",
      "Edit:.claude/**",
      "Write:frontend/**",
      "Write:backend/**",
      "Write:.claude/**",
      "Bash(bash /home/hduser/exam-prep-system-package-20260330/.claude/skills/list-users.sh)",
      "WebSearch",
      "Bash(ls:*)"
    ]
  },
  "projectContext": {
    "frontendDirectory": "frontend",
    "backendDirectory": "backend",
    "packageJsonPath": "frontend/package.json",
    "description": "密评备考系统 - Vue3前端 + Express后端 + PostgreSQL数据库",
    "type": "fullstack-web-app",
    "frontendFramework": "vue3",
    "backendFramework": "express",
    "database": "postgresql",
    "apiBasePath": "/api/v2",
    "keyFiles": [
      "frontend/src/App.vue",
      "backend/server.js",
      "backend/unified-stats-api.js",
      "frontend/src/components/LoginModal.vue"
    ]
  },
  "preferences": {
    "alwaysUseGlobForFileSearch": true,
    "alwaysUseGrepForContentSearch": true,
    "avoidFindCommand": true,
    "maxSearchResults": 20,
    "preferEditOverWrite": true,
    "skipNodeModules": true,
    "compactOutput": true
  },
  "searchExcludePatterns": [
    "node_modules/**",
    "dist/**",
    ".git/**",
    "*.min.js",
    "*.min.css",
    "*.bak",
    "*.log"
  ],
  "filePriorityPatterns": [
    "frontend/src/components/**/*.vue",
    "frontend/src/App.vue",
    "backend/*.js",
    "backend/api*.js",
    ".claude/**"
  ]
}
