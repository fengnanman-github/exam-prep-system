{
  "projectContext": {
    "frontendDirectory": "frontend",
    "backendDirectory": "backend",
    "packageJsonPath": "frontend/package.json",
    "description": "密评备考系统 - Vue.js 前端 + Node.js 后端",
    "type": "fullstack-web-app",
    "frontendFramework": "vue3",
    "backendFramework": "express",
    "database": "postgresql",
    "apiBasePath": "/api/v2"
  },
  "preferences": {
    "alwaysUseGlobForFileSearch": true,
    "alwaysUseGrepForContentSearch": true,
    "avoidFindCommand": true,
    "maxSearchResults": 50,
    "preferEditOverWrite": true,
    "skipNodeModules": true
  },
  "permissions": {
    "allow": [
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(netstat:*)",
      "Bash(sudo:*)",
      "Bash(xargs:*)",
      "Bash(curl:*)",
      "Bash(python3:*)",
      "Bash(npm run build:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(pip3 install:*)",
      "Bash(apt-get:*)",
      "Bash(apt-get install:*)",
      "Bash(npm install:*)",
      "Bash(node:*)",
      "Bash(pkill:*)",
      "Bash(chmod:*)",
      "Bash(grep:*)",
      "Bash(chown:*)",
      "Bash(cat:*)",
      "Bash(wc:*)",
      "Bash(du:*)",
      "Bash(git --version)",
      "Bash(git init:*)",
      "Bash(git config:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(gh:*)",
      "Bash(git remote add:*)",
      "Bash(git push:*)",
      "Bash(ssh-keygen:*)",
      "Bash(git remote set-url:*)",
      "Bash(ssh:*)",
      "Bash(export:*)",
      "Bash(echo:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm run)",
      "Bash(psql:*)",
      "Bash(PGPASSWORD=* psql:*)"
    ]
  },
  "searchExcludePatterns": [
    "node_modules/**",
    "dist/**",
    ".git/**",
    "*.min.js",
    "*.min.css"
  ],
  "filePriorityPatterns": [
    "frontend/src/**/*.vue",
    "frontend/src/components/**",
    "backend/**/*.js",
    "backend/api*.js"
  ]
}
